depends idris/pack

cmd : "Install Idris Language Server" \
      pack install-app idris2-lsp

backup ~/.config/pack/pack.toml

cmd : "Add lsp to must-have apps and whitelist" \
      sed -e \'s/^\# apps.*=.*$/apps       = [ \"idris2-lsp\" ]\\nwhitelist  = [\"idris2-lsp\",\"pack\"]/\' -i ~/.config/pack/pack.toml

cmd : "Turn-on rlwrap" \
      sed -e \'s/^repl.rlwrap = false$/repl.rlwrap = \"-pGreen -aN\"/\' -i ~/.config/pack/pack.toml
      
